{
  "name": "writing-copilot",
  "version": "0.1.0",
  "description": "Obsidian plugin scaffold for the Writing Copilot review workflow.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest run"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "writing"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^22.15.30",
    "esbuild": "^0.25.5",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@codemirror/merge": "^6.12.1",
    "obsidian": "latest"
  }
}
